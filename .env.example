# Credenciales DataComex — OPCIONALES.
#
# Sin ellas, la actualización (./update-data.sh) usa la vía PÚBLICA CSV, que no
# requiere cuenta y trae los datos NACIONALES de todo el histórico.
#
# Con una cuenta gratuita (registro en https://datacomex.comercio.es/User) se
# añade el desglose PROVINCIAL de Aragón (cuotas Aragón/Zaragoza, ficha provincial).
#
# Uso: copia este archivo a .env y rellena tus credenciales. `run.sh` y
# `update-data.sh` cargan .env automáticamente, así que basta con:
#   cp .env.example .env   # luego edita .env y pega tu token
#   ./update-data.sh

DATACOMEX_EMAIL=
DATACOMEX_PASSWORD=

# Alternativa a email/contraseña: token JWT del botón «Obtener Token» de la
# página de ayuda de la API de DataComex.
# DATACOMEX_TOKEN=
